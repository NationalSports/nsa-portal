# ── NSA bot worker config ──────────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit the real .env (see .gitignore).

# Same Supabase project the portal uses (REACT_APP_SUPABASE_URL), but with the
# SERVICE-ROLE key so the worker can read/update assigned_todos and bypass RLS.
# Find both in: Supabase dashboard → Project Settings → API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The team_members id the portal assigns bot tasks to (from migration 00099).
BOT_MEMBER_ID=bot-claude

# How often to poll for queued tasks, in milliseconds.
POLL_INTERVAL_MS=30000

# Path to the Claude Code CLI (usually just "claude" if it's on PATH).
CLAUDE_BIN=claude

# Vendor portal credentials the agent uses to log in. These are injected into
# the task prompt at runtime. Keep this file locked down (chmod 600) — or, for
# real security, load them from the macOS Keychain instead (see SETUP.md).
ADIDAS_CLICK_URL=https://www.adidasclick.com
ADIDAS_CLICK_USER=
ADIDAS_CLICK_PASS=

# Safety: the agent must NEVER place/submit an order. It fills the cart and
# stops at needs_review. Leave this as 1 unless you really know what you want.
STOP_BEFORE_SUBMIT=1
